<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme.  Theme.AppCompat.Light.NoActionBar Theme.MaterialComponents.Light.NoActionBar-->
    <style name="Theme.Review" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/azul</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <!--<item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimary</item>-->

        <!-- Customize your theme here. -->
        <!-- Forzar el tema Claro -->
        <item name="android:forceDarkAllowed" tools:targetApi="q">true</item>
    </style>

    <style name="btnGeneral" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:textColor">@color/azul_solido</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="btnCrearGuia" parent="@android:style/Widget.Button">
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Botones normales Widget.MaterialComponents.Button.OutlinedButton-->
    <style name="btnGenerales" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">30dp</item>
        <item name="android:text">@string/btnNuevaGuia</item>
        <item name="android:textColor">@color/azul_solido</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radioContorno</item>
        <item name="strokeWidth">@dimen/anchoContorno</item>
        <item name="strokeColor">@android:color/holo_blue_dark</item>
        <item name="rippleColor">@android:color/holo_blue_bright</item>
    </style>
    
    <style name="Theme.TextMain" parent="Theme.Review">
        <item name="android:fontFamily">@font/inter</item>
    </style>
</resources>