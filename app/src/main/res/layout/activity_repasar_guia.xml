<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.jonathanev.review.Activities.Activity_RepasarGuia">

    <include
        android:id="@+id/barra_superior_regreso"
        layout="@layout/barra_superior_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvPregResp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:elevation="8dp"
        app:cardCornerRadius="42dp"
        app:layout_constraintBottom_toTopOf="@+id/adView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/barra_superior_regreso">

        <LinearLayout
            android:id="@+id/layoutContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layoutBtnsCuestionario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal"
                android:padding="10dp">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <ImageView
                        android:id="@+id/imgvPrevious"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:layout_gravity="left"
                        android:layout_marginTop="10dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:src="@drawable/ic_circle_left_right"
                        tools:ignore="ContentDescription" />

                    <ImageView
                        android:id="@+id/imgvNext"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:layout_gravity="right"
                        android:layout_marginTop="10dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:rotationY="180"
                        android:src="@drawable/ic_circle_left_right"
                        tools:ignore="ContentDescription" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/imgvPregResp"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="25dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="6dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:padding="10dp"
                    android:src="@drawable/ic_preg_resp"
                    tools:ignore="ContentDescription" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilContenidoPregResp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="6dp"
                android:hint="@string/etPregunta"
                android:labelFor="@+id/tvContenidoPregResp"
                app:endIconMode="clear_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPregResp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:autofillHints="testHint"
                    android:focusable="false"
                    android:gravity="top"
                    android:inputType="text|textMultiLine"
                    android:scrollbars="vertical"
                    android:textSize="18sp"
                    android:background="@android:color/transparent" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

