<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondopantallas"
    tools:context="com.jonathanev.repasar.MainActivity">

    <include
        android:id="@+id/barra_superior"
        layout="@layout/barra_superior"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guiaImagenPrincipal"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent=".20" />

    <ImageView
        android:id="@+id/imgPrincipal"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:src="@drawable/estudiantes"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guiaImagenPrincipal" />

    <Button
        android:id="@+id/btnNuevaGuiaEstudio"
        app:layout_constraintTop_toBottomOf="@+id/imgPrincipal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnAbrirGuiaEstudioInhabilitado"
        style="@style/btnGenerales"/>

    <!-- Por el momento no se usa -->
    <Button
        android:id="@+id/btnAbrirGuiaEstudioInhabilitado"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@+id/imgPrincipal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnNuevaGuiaEstudio"
        style="@style/btnInhabilitado"/>

    <Button
        android:id="@+id/btnAbrirGuiaEstudioHabilitado"
        app:layout_constraintTop_toBottomOf="@+id/imgPrincipal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnNuevaGuiaEstudio"
        style="@style/btnGenerales"/>
</androidx.constraintlayout.widget.ConstraintLayout>