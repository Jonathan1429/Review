<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:background="@color/background_app"
    tools:context="com.jonathanev.review.ui.fragment.FragmentListGuides">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/lvGuiasEstudioNew"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnCreateGuide"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreateGuide"
        style="@style/btnCrearGuia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/ic_filter_state_crear_guia"
        android:layoutDirection="ltr"
        android:text="@string/btnCrearArchivo"
        app:backgroundTint="@null"
        app:icon="@drawable/plus"
        app:iconPadding="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>