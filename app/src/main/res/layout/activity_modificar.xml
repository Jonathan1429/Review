<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.jonathanev.review.UI.View.Activity_Cuestionario">

    <include
        android:id="@+id/barra_superior_regreso"
        layout="@layout/barra_superior_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvPregResp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:elevation="8dp"
        app:cardCornerRadius="42dp"
        app:layout_constraintBottom_toTopOf="@+id/adView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/barra_superior_regreso">

        <LinearLayout
            android:id="@+id/layoutContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <FrameLayout
                        android:id="@+id/imgvPrevious"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_margin="10dp"
                        android:padding="6dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_circle_left_right"
                            tools:ignore="ContentDescription" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imgvImage"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_margin="10dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:src="@drawable/ic_file_image"
                            tools:ignore="ContentDescription" />

                        <ImageView
                            android:id="@+id/imgvEliminar"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_margin="10dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:src="@drawable/ic_trash"
                            tools:ignore="ContentDescription" />

                        <ImageView
                            android:id="@+id/imgvSelColor"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_margin="10dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:src="@drawable/ic_palette"
                            tools:ignore="ContentDescription" />

                        <ImageView
                            android:id="@+id/imgvQuitColor"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_margin="10dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:src="@drawable/ic_eraser"
                            tools:ignore="ContentDescription" />

                        <ImageView
                            android:id="@+id/imgvCancelar"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_margin="10dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:src="@drawable/ic_cancel"
                            android:visibility="gone"
                            tools:ignore="ContentDescription" />

                        <ImageView
                            android:id="@+id/imgvPregResp"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_margin="10dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:src="@drawable/ic_preg_resp"
                            tools:ignore="ContentDescription" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/imgvNext"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="end"
                        android:layout_margin="10dp"
                        android:padding="6dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:rotationY="180"
                            android:src="@drawable/ic_circle_left_right"
                            tools:ignore="ContentDescription" />
                    </FrameLayout>
                </FrameLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/lblPregResp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="Pregunta"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilContenidoPregResp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="6dp"
                android:hint="@string/lblCuestionario"
                android:labelFor="@+id/tvContenidoPregResp"
                android:padding="15dp"
                android:visibility="visible"
                app:endIconMode="clear_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPregResp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:autofillHints="testHint"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:inputType="text|textMultiLine"
                    android:scrollbars="vertical"
                    android:textSize="18sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.davemorrissey.labs.subscaleview.SubsamplingScaleImageView
                android:id="@+id/ivImagen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="20dp"
                android:visibility="gone"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- AdMob app ID: ca-app-pub-5116088101296740/3112731307 -->
    <!-- Sample AdMob app ID: ca-app-pub-3940256099942544/6300978111 -->
    <com.google.android.gms.ads.AdView xmlns:ads="http://schemas.android.com/apk/res-auto"
        android:id="@+id/adView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        ads:adSize="BANNER"
        ads:adUnitId="ca-app-pub-3940256099942544/6300978111"
        ads:layout_constraintBottom_toBottomOf="parent"
        ads:layout_constraintEnd_toEndOf="parent"
        ads:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>