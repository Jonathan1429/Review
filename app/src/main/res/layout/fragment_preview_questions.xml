<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="8dp"
    android:background="@color/background_app"
    tools:context=".ui.fragment.FragmentPreviewQuestions">

    <TextView
        android:id="@+id/lblQuestions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Preguntas"
        android:textSize="24sp"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/reciclerPreviewQuestions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lblQuestions"
        app:layout_constraintBottom_toTopOf="@+id/btnApply"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApply"
        style="@style/btnCrearGuia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/ic_filter_state_crear_guia"
        android:layoutDirection="ltr"
        android:text="@string/btnAddQuestions"
        app:backgroundTint="@null"
        app:icon="@drawable/plus"
        app:iconPadding="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>