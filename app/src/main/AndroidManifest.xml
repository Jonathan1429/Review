<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- BUGS
         1.- (CREENCIA) Probar copiar un texto de WhatsApp, creo que cuando se copia y se pega en la App
             trae textos extraños.
         NO COMPROBADO AÚN

         2.- Cuando no hay guías está en blanco.
         (SOLUCIONADO)

         3.- En la creación de una guía da doble vuelta en lugar de 180°
         SOLUCIONADO

         4.- Ocurrió un error al momento de crear una guía: estuve copiando lo que estaba en chatGPT
             y cambie de colores partes del texto

         5.- El título de modificando no aparece cuando se va a modificar desde el repaso de una guía
         SOLUCIONADO

         6.- Los iconos de las opciones están bugueados ya que a veces no funciona esa parte,
             no suele funcionar cuando estas en la ultima pregunta, regresas y vuelves delante,
             anteriormente debe estar una imagen en la respuesta

         7.- Reiniciar el provider siempre que se de click en el botón Abrir Guias.

         MEJORAS
         1.- Usar la obtención de la variable mutable de una guia al dar click en una guia en específico.

         2.- Poner un mensaje al momento de cambiar el nombre de una guia.

         3.- Agregar un progress bar cuando esté cargando las guias de estudio
         PRUEBAS

         1.- Cambiar el nombre de una guia y que esta ya exista y le des en continuar

         2.- Cambiar el nombre de una guia y que esta no exista.

         3.- Probar que cuando le des en crear una nueva guia lo haga correctamente
    -->
    <application
        android:name=".ReviewApp"
        android:allowBackup="true"
        android:icon="@drawable/img_inicio"
        android:label="@string/nameApp"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Review"
        android:requestLegacyExternalStorage="true">
        <!-- Sample AdMob app ID: ca-app-pub-3940256099942544~3347511713 -->
        <!-- AdMob app ID: ca-app-pub-5116088101296740~9876600140 -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />

        <!-- El WindowSoft... es para que no se muevan los componentes cuando se habra el teclado -->
        <activity
            android:name="com.jonathanev.review.UI.View.Activity_Modificar"
            android:windowSoftInputMode="adjustPan"
            android:exported="false"
            android:screenOrientation="userPortrait" />

        <activity
            android:name="com.jonathanev.review.UI.View.Activity_RepasarGuia"
            android:exported="false"
            android:screenOrientation="userPortrait" />

        <!-- El WindowSoft... es para que no se muevan los componentes cuando se habra el teclado -->
        <activity
            android:name="com.jonathanev.review.UI.View.Activity_Cuestionario"
            android:windowSoftInputMode="adjustPan"
            android:exported="true"
            android:screenOrientation="userPortrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.jonathanev.review.UI.View.MainActivity"
            android:exported="true"
            android:screenOrientation="userPortrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>