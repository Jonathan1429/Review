<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.jonathanev.review">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- BUGS
         1.- Hay que verificar que el botón de eliminar funcione correctamente.
         (SOLUCIONADO)

         2.- Si agregamos los colores  sin orden el archivo no se crea o modifica correctamente,
             ya sea en el apartado de crear una nueva guia o en modificar.
         (SOLUCIONADO)

         3.- Si cambias de color 2 veces en la misma palabra se guardan colores antiguos y se hace
             una revoltura.
         (SOLUCIONADO)

         4.- Si vamos agregar una nueva pregunta y le doy para atrás no se guardará esa pregunta
             si no hay campos vacios.

         MEJORAS

         5.- Cambiar los botónes de siguiente y atras por iconos con flecha de siguiente y atras.

         6.- No se puede cambiar colores a letras que ya tenía un color anteriormente.
         (SOLUCIONADO)
    -->
    <application
        android:allowBackup="true"
        android:icon="@drawable/estudiantes"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Review">
        <activity
            android:name="com.jonathanev.review.Activities.Activity_Modificar"
            android:exported="false" />
        <!-- Sample AdMob app ID: ca-app-pub-3940256099942544~3347511713 -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-5116088101296740~3054801927" />

        <activity
            android:name="com.jonathanev.review.Activities.Activity_RepasarGuia"
            android:exported="false"
            android:screenOrientation="userPortrait" />
        <activity
            android:name="com.jonathanev.review.Activities.Activity_Cuestionario"
            android:exported="true"
            android:screenOrientation="userPortrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.jonathanev.review.MainActivity"
            android:exported="true"
            android:screenOrientation="userPortrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

