<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.jonathanev.repasar">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- BUGS
         1.- No funciona correctamente cuando usamos el botón de atrás en modificar, después
             de eso le damos en siguiente y finalmente guardar.

         2.- No funciona correctamente cuando usamos el botón de atrás en modificar, después
             de eso le damos en Guardar teniendo por ejemplo 20 preguntas por delante y truena.

         3.- Hay que verificar que el botón de eliminar funcione correctamente.

         4.- Después de pasar todas las preguntas y al agregar una mas le das guardar truena la app.

         5.- Si nosotros le damos click en el botón de guardar al final se guarda una pregunta en
             blanco.

         NOTA: El botón atras funciona pero unicamente antes de agregar mas preguntas,
         cuando llegas a esa opción no puedes usar el botón de atrás sino no jala.

         MEJORAS
         1.- Hay que quitar un botón de btnGuardarGuia, que el código quede en uno solo.

         5.- Al momento de estar modificando una guía no tenemos botón de atras y estaría bueno
             implementarlo
             (IMPLEMENTADO PERO NO FUNCIONAL).

         6.- Cambiar los botónes de siguiente y atras por iconos con flecha de siguiente y atras.

         7.- Que puedas guardar las guías directamente desde la primer pregunta.
    -->
    <application
        android:allowBackup="true"
        android:icon="@drawable/estudiantes"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Repasar">
        <activity
            android:name=".Activities.Activity_Modificar"
            android:exported="false" />
        <!-- Sample AdMob app ID: ca-app-pub-3940256099942544~3347511713 -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-5116088101296740~3054801927" />

        <activity
            android:name=".Activities.Activity_RepasarGuia"
            android:exported="false"
            android:screenOrientation="userPortrait" />
        <activity
            android:name=".Activities.Activity_Cuestionario"
            android:exported="true"
            android:screenOrientation="userPortrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="userPortrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>