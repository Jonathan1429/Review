<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- BUGS
         1.- Si pegas un texto la última letra te la pone de color(Modificando, Creación).
         SOLUCIONADO

         2.- Al darle next estando en respuesta avanzas a la parte de la Respuesta y debes de
         ir a la pregunta, no directamente a la respuesta(Creando guia)
         SOLUCIONADO

         3.- Lo que salga con este número de color 52223 decirle que no ponga etiquetas, esto lo
         tendríamos que poner en el modificando y creando
         SOLUCIONADO

         4.- Error cuando modificas una guía dentro de una carpeta, parece que el error sale después
             de que se guarda, ya que se abre la vista de repasar la guia
         SOLUCIONADO

         5.- Verificar que el nombre del archivo no contenga una /.
         SOLUCIONADO

         6.- Si vas a mover el archivo a una carpeta verificar que ahí no se encuentre el archivo y
             advertir que si continua se va a borrar.
         SOLUCIONADO

         7.- (CREENCIA) Probar copiar un texto de WhatsApp, creo que cuando se copia y se pega en la App
             trae textos extraños.

         MEJORAS
         1.- Si ya tienes lleno el txt con un texto que sea diferente a la media... y le das click
             al icono para agregar una imagen, advertirle que se borrará si continua.
         2.- El icono de guardar se encima con el titulo, solucionar eso.
         SOLUCIONADO

         3.- Eliminar espacios de las orillas en modificar y crear la guia.
         SOLUCIONADO

         PROBAR
         1.- Probar los mismos nombres en diferentes carpetas para ver si se borran o que pasa
         2.- Copiar y pegar un texto con color, copiar un texto(nueva guia, modificación de guia)
    -->
    <application
        android:name=".ReviewApp"
        android:allowBackup="true"
        android:icon="@drawable/img_inicio"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Review"
        android:requestLegacyExternalStorage="true">
        <!-- Sample AdMob app ID: ca-app-pub-3940256099942544~3347511713 -->
        <!-- AdMob app ID: ca-app-pub-5116088101296740~9876600140 -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />

        <!-- El WindowSoft... es para que no se muevan los componentes cuando se habra el teclado -->
        <activity
            android:name="com.jonathanev.review.UI.View.Activity_Modificar"
            android:windowSoftInputMode="adjustPan"
            android:exported="false"
            android:screenOrientation="userPortrait" />

        <activity
            android:name="com.jonathanev.review.UI.View.Activity_RepasarGuia"
            android:exported="false"
            android:screenOrientation="userPortrait" />

        <!-- El WindowSoft... es para que no se muevan los componentes cuando se habra el teclado -->
        <activity
            android:name="com.jonathanev.review.UI.View.Activity_Cuestionario"
            android:windowSoftInputMode="adjustPan"
            android:exported="true"
            android:screenOrientation="userPortrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.jonathanev.review.UI.View.MainActivity"
            android:exported="true"
            android:screenOrientation="userPortrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>